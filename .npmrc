# Scoped packages publish to a private registry by default (GitHub Packages).
# Uncomment / adjust per the confirmed registry decision (Фаза 0).
# @iskra-ui:registry=https://npm.pkg.github.com

# Strictness for reproducible, hoisting-safe installs across the workspace.
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
