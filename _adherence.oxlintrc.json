{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Badge/**",
              "components/Button/**",
              "components/Checkbox/**",
              "components/Icon/**",
              "components/Radio/**",
              "components/Sidebar/**",
              "components/Switch/**",
              "components/TextField/**",
              "design-canvas.jsx",
              "logo/**",
              "ui_kits/user-webui/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|dot|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, dot, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconBefore|iconAfter|iconOnly|loading|fullWidth|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconBefore, iconAfter, iconOnly, loading, fullWidth, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|indeterminate|size|label|description|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, indeterminate, size, label, description, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|label|description|disabled|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: value, size, label, description, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:collapsed|onToggle|activeItem|onNavigate|variant|theme|badges|className|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: collapsed, onToggle, activeItem, onNavigate, variant, theme, badges, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:operator|admin)$/]",
        "message": "<Sidebar> variant must be one of 'operator' | 'admin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:|theme-cold|theme-warm)$/]",
        "message": "<Sidebar> theme must be one of '' | 'theme-cold' | 'theme-warm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|size|label|description|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, size, label, description, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|hint|error|required|iconBefore|clearable|onClear|clearLabel|className|wrapClassName|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: size, label, hint, error, required, iconBefore, clearable, onClear, clearLabel, className, wrapClassName."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
