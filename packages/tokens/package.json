{
  "name": "@iskra-ui/tokens",
  "version": "0.1.1",
  "description": "Искра.DCI design tokens (DTCG) → CSS variables + typed TS map via Style Dictionary.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iskra-dctech/iskra.ui-kit.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://github.com/iskra-dctech/iskra.ui-kit#readme",
  "bugs": {
    "url": "https://github.com/iskra-dctech/iskra.ui-kit/issues"
  },
  "keywords": [
    "iskra",
    "design-system",
    "datacenter",
    "ui-kit",
    "tokens",
    "dtcg",
    "css-variables"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./dist/tokens.json",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@iskra-ui/tsconfig": "workspace:*",
    "style-dictionary": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
