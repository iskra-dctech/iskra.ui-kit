{
  "name": "@iskra-ui/vue",
  "version": "0.1.2",
  "description": "Искра.DCI Vue 3 component library — API parity with @iskra-ui/react over a shared headless core and token layer.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iskra-dctech/iskra.ui-kit.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/iskra-dctech/iskra.ui-kit#readme",
  "bugs": {
    "url": "https://github.com/iskra-dctech/iskra.ui-kit/issues"
  },
  "keywords": [
    "iskra",
    "design-system",
    "datacenter",
    "ui-kit",
    "vue",
    "vue3",
    "components"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": ">=3.4"
  },
  "dependencies": {
    "@iskra-ui/core": "workspace:*",
    "@iskra-ui/i18n": "workspace:*",
    "@iskra-ui/icons": "workspace:*",
    "@iskra-ui/tokens": "workspace:*"
  },
  "devDependencies": {
    "@iskra-ui/react": "workspace:*",
    "@iskra-ui/styles": "workspace:*",
    "@iskra-ui/tokens": "workspace:*",
    "@iskra-ui/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
